{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'owner')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner'",
        ".validate": "newData.hasChildren(['name', 'role', 'fullAccess']) && newData.child('role').val() === 'owner' && newData.child('fullAccess').val() === true"
      }
    },
    "workspaces": {
      "$workspaceId": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner' && root.child('users').child(auth.uid).child('fullAccess').val() === true",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner' && root.child('users').child(auth.uid).child('fullAccess').val() === true",
        ".validate": "$workspaceId === 'mfci-main' && newData.hasChild('meta') && (newData.child('meta').child('schemaVersion').val() === 4 || newData.child('meta').child('schemaVersion').val() === 5 || newData.child('meta').child('schemaVersion').val() === 6)"
      }
    },
    "publicLeads": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner' && root.child('users').child(auth.uid).child('fullAccess').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner' && root.child('users').child(auth.uid).child('fullAccess').val() === true"
    },
    "publicLeadImages": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner' && root.child('users').child(auth.uid).child('fullAccess').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner' && root.child('users').child(auth.uid).child('fullAccess').val() === true"
    }
  }
}
